	"#str_303851"	"Caporal Kane, venez par ici."
	"#str_303852"	"Passez par là, caporal Kane."
	"#str_303853"	"Allez, caporal Kane, on y va."
	"#str_303854"	"Hé, caporal Kane !"
	"#str_303855"	"Beau boulot, caporal Kane."
	"#str_303856"	"Attention, Kane !"
	"#str_303857"	"Caporal Kane, vous aurez besoin de ça."
	"#str_303858"	"Par ici, caporal Kane."
