	"#str_303861"	"Caporal Kane !"
	"#str_303862"	"Bien joué, Kane !"
	"#str_303863"	"Kane, attention !"
	"#str_303864"	"Attention, Kane !"
	"#str_303865"	"Attendez, je répare ça."
	"#str_303866"	"Je vais vous réparer votre armure."
