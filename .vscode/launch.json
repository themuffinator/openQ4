        "+set",
        "developer",
        "1",
        "+set",
        "com_skipLoadingContinue",
        "1",
        "+set",
        "r_fullscreen",
        "0",
        "+set",
        "g_autoScreenshot",
        "0",
        "+set",
        "g_autoScreenshotDelayMs",
        "10000",
        "+set",
        "g_autoScreenshotQuit",
        "0",
        "+set",
        "fs_basepath",
        "C:\\Program Files (x86)\\Steam\\steamapps\\common\\Quake 4",
        "+set",
        "fs_savepath",
        "C:\\Program Files (x86)\\Steam\\steamapps\\common\\Quake 4",
        "+set",
        "fs_devpath",
        "${workspaceFolder}\\install",
        "+set",
        "fs_game",
        "openbase",
        "+set",
        "si_gameType",
        "singleplayer",
        "+map",
        "game/airdefense1"
      ],
      "cwd": "${workspaceFolder}\\install",
      "console": "integratedTerminal"
    }
  ]
}
